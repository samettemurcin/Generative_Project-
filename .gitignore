# =============================================================================
# .gitignore — generative_project_1
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# -----------------------------------------------------------------------------
# IDE & editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Jupyter notebooks — checkpoints only, keep .ipynb files
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Project runtime outputs — never commit large binary files
# -----------------------------------------------------------------------------
outputs/
checkpoints/

# Keep the outputs/ directory itself tracked (for structure)
!outputs/.gitkeep
!checkpoints/.gitkeep

# -----------------------------------------------------------------------------
# Logs — generated at runtime
# -----------------------------------------------------------------------------
logs/
*.log
*.jsonl

# Keep logs/ directory tracked
!logs/.gitkeep

# -----------------------------------------------------------------------------
# Model cache — HuggingFace downloads, can be gigabytes
# -----------------------------------------------------------------------------
.cache/
~/.cache/huggingface/
huggingface_cache/

# -----------------------------------------------------------------------------
# Data — never commit raw datasets
# -----------------------------------------------------------------------------
data/
datasets/
*.npz
*.npy
*.hdf5
*.h5
*.csv
*.parquet

# -----------------------------------------------------------------------------
# Secrets & credentials
# -----------------------------------------------------------------------------
.env
.env.*
secrets.yaml
secrets.json
*_secret*
*_key*
*.pem

# -----------------------------------------------------------------------------
# OS & system
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# pytest & coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# -----------------------------------------------------------------------------
# Ruff linter cache
# -----------------------------------------------------------------------------
.ruff_cache/

# -----------------------------------------------------------------------------
# Temporary & scratch files
# -----------------------------------------------------------------------------
*.tmp
*.bak
scratch/